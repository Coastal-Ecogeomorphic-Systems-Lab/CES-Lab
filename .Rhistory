ylim = c(24, 50),
expand = FALSE
) +
theme_bw() +
theme(
axis.text = element_blank(),
axis.title = element_blank(),
axis.ticks = element_blank(),
panel.grid = element_blank(),
panel.border = element_rect(color = "black", linewidth = 0.6)
)
# ---------------------------------------------------------
# 8. Combine main map and inset
# ---------------------------------------------------------
final_map <- ggdraw() +
draw_plot(main_map) +
draw_plot(inset_map, x = 0.77, y = 0.1, width = 0.2, height = 0.2)
print(final_map)
# ---------------------------------------------------------
# 9. Save outputs
# ---------------------------------------------------------
ggsave(
filename = "irish_adoption_article_map_greyscale_no-counts.png",
plot = final_map,
width = 11,
height = 8,
dpi = 300
)
ggsave(
filename = "irish_adoption_article_map_greyscale_no-counts.pdf",
plot = final_map,
width = 11,
height = 8
)
# =========================================================
# Irish Adoption Articles by City
# Grayscale graduated symbology + theme_bw
# Pittsburg shown separately as black dot with bold label
# Variable label offsets for other cities based on article class
# Includes U.S. locator inset
# =========================================================
# Install if needed:
# install.packages(c("readxl", "sf", "ggplot2", "dplyr", "tigris", "cowplot"))
library(readxl)
library(sf)
library(ggplot2)
library(dplyr)
library(tigris)
library(cowplot)
options(tigris_use_cache = TRUE)
# ---------------------------------------------------------
# Read Excel file
# ---------------------------------------------------------
df <- read_excel("irish_adoption_gis.xlsx", sheet = "GIS_Data")
names(df) <- tolower(names(df))
df <- df %>%
mutate(
latitude = as.numeric(latitude),
longitude = as.numeric(longitude),
article_count = as.numeric(article_count)
) %>%
filter(!is.na(latitude), !is.na(longitude), !is.na(city))
# ---------------------------------------------------------
# Separate Pittsburg
# ---------------------------------------------------------
df_pitt <- df %>%
filter(city == "Pittsburg")
df_other <- df %>%
filter(city != "Pittsburg")
pts_all <- st_as_sf(df, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
pts_other <- st_as_sf(df_other, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
pts_pitt <- st_as_sf(df_pitt, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
# ---------------------------------------------------------
# Get U.S. state boundaries
# ---------------------------------------------------------
states_sf <- states(cb = TRUE, year = 2023) %>%
st_transform(4326)
states_conus <- states_sf %>%
filter(!STUSPS %in% c("AK", "HI", "PR"))
# ---------------------------------------------------------
# Build study-area extent from all points
# ---------------------------------------------------------
bbox <- st_bbox(pts_all)
xmin <- as.numeric(bbox["xmin"]) - 1.5
xmax <- as.numeric(bbox["xmax"]) + 1.5
ymin <- as.numeric(bbox["ymin"]) - 1.0
ymax <- as.numeric(bbox["ymax"]) + 1.0
study_area_box <- st_as_sfc(
st_bbox(
c(xmin = xmin, ymin = ymin, xmax = xmax, ymax = ymax),
crs = st_crs(pts_all)
)
)
states_crop <- st_crop(
states_conus,
xmin = xmin, xmax = xmax,
ymin = ymin, ymax = ymax
)
# ---------------------------------------------------------
# Main map
# ---------------------------------------------------------
main_map <- ggplot() +
geom_sf(
data = states_crop,
fill = "white",
color = "gray50",
linewidth = 0.4
) +
geom_sf(
data = pts_other,
shape = 21,
fill = "gray70",
size = 3.25
) +
geom_sf(
data = pts_pitt,
shape = 21,
fill = "black",
size = 3.25
) +
geom_text(
data = df_other,
aes(
x = longitude,
y = latitude,
label = city),
size = 3.5,
nudge_y = 0.11,
) +
geom_text(
data = df_pitt,
aes(
x = longitude,
y = latitude,
label = city
),
size = 4,
nudge_y = 0.115,
fontface = "bold"
) +
coord_sf(
xlim = c(xmin, xmax),
ylim = c(ymin, ymax),
expand = FALSE
) +
labs(
title = "Irish Adoption Articles by City",
x = NULL,
y = NULL
) +
theme_bw(base_size = 12) +
theme(
panel.grid.major = element_line(color = "gray88", linewidth = 0.3),
panel.grid.minor = element_blank(),
panel.border = element_rect(color = "black", linewidth = 0.8),
axis.text = element_text(size = 9, color = "black"),
axis.title = element_blank(),
plot.title = element_text(face = "bold", size = 15),
)
# ---------------------------------------------------------
# 7. U.S. inset map
# ---------------------------------------------------------
inset_map <- ggplot() +
geom_sf(
data = states_conus,
fill = "white",
color = "gray60",
linewidth = 0.25
) +
geom_sf(
data = study_area_box,
fill = NA,
color = "black",
linewidth = 0.8
) +
coord_sf(
xlim = c(-125, -66),
ylim = c(24, 50),
expand = FALSE
) +
theme_bw() +
theme(
axis.text = element_blank(),
axis.title = element_blank(),
axis.ticks = element_blank(),
panel.grid = element_blank(),
panel.border = element_rect(color = "black", linewidth = 0.6)
)
# ---------------------------------------------------------
# 8. Combine main map and inset
# ---------------------------------------------------------
final_map <- ggdraw() +
draw_plot(main_map) +
draw_plot(inset_map, x = 0.77, y = 0.1, width = 0.2, height = 0.2)
print(final_map)
# ---------------------------------------------------------
# 9. Save outputs
# ---------------------------------------------------------
ggsave(
filename = "irish_adoption_article_map_greyscale_no-counts.png",
plot = final_map,
width = 11,
height = 8,
dpi = 300
)
ggsave(
filename = "irish_adoption_article_map_greyscale_no-counts.pdf",
plot = final_map,
width = 11,
height = 8
)
library(ggplot2)
library(emmeans)
library(car)
install.packages("car")
library(tidyverse)
#library(ggplot2)
library(emmeans)
library(car)
library(nnet)  # For multinomial logistic regression
#library(dplyr)
#library(tidyr)
library(gsheet)
library(forcats)
library(broom)
library(ggsci)
# Load required libraries
library(tidyverse)
#library(ggplot2)
library(emmeans)
library(car)
library(nnet)  # For multinomial logistic regression
#library(dplyr)
#library(tidyr)
library(gsheet)
library(forcats)
library(broom)
library(ggsci)
df <- gsheet2tbl("https://docs.google.com/spreadsheets/d/1WOBmzjOojN_qlxb7L8TsYR02FruRlzxNTUkyRY3pik8/edit?usp=sharing")
# Create bins for the wind angle variable
df$Angle_Bin <- cut(df$Ang,
breaks = c(113.5, 118.5, 123.5, 128.5, 133.5),
labels = c("113.5-118.5", "118.5-123.5", "123.5-128.5", "128.5-133.5"),
include.lowest = TRUE)
# Set the reference level for the angle bins
df$Angle_Bin <- relevel(df$Angle_Bin, ref = "118.5-123.5")
df %>% count(Angle_Bin)
#__________________________________________________________________________________
# Model 1, Wind Reduction as a function of Wind Speed and Wind Angle bins
m1 <- lm(Red ~ Ws + Angle_Bin, data = df)
summary(m1)
car::Anova(m1, type = 3)
model_out <- broom::tidy(m1, conf.int = TRUE) %>%
mutate(cell = paste0(round(estimate,2), " (", round(conf.low,2), ", ", round(conf.high,2), ")"),
p = paste0(round(p.value, 3))) %>%
mutate(p = if_else(p == "0", "< 0.001", p))
#Model 1 Graph
# Define coefficients from your model
intercept <- 10.84  # Adjust as per your model
coef_Ws <- 7.10
coef_Angle113.5_118.5 <- -0.7
coef_Angle123.5_128.5 <- 0.36
coef_Angle128.5_133.5 <- 1.36
#coef_Ws_Angle113.5_118.5 <- 0.4287
#coef_Ws_Angle123.5_128.5 <- -0.1973
#coef_Ws_Angle128.5_133.5 <- 0.9283
# Create a sequence of Wind Speed values
Ws_values <- seq(0, 20, by = 0.5)
prediction_data <- data.frame(Ws = Ws_values)
# Calculate predictions for each angle bin
prediction_data <- prediction_data %>%
mutate(
pred_118_123 = intercept + coef_Ws * Ws,
pred_113_118 = intercept + coef_Ws * Ws + coef_Angle113.5_118.5 * 1,
pred_123_128 = intercept + coef_Ws * Ws + coef_Angle123.5_128.5 * 1,
pred_128_133 = intercept + coef_Ws * Ws + coef_Angle128.5_133.5 * 1
)
# Reshape data to long format for ggplot2
long_data <- prediction_data %>%
pivot_longer(cols = starts_with("pred_"),
names_to = "Angle_Bin",
values_to = "Prediction") %>%
mutate(Angle_Bin = recode(Angle_Bin,
pred_118_123 = "Angle 118.5-123.5",
pred_113_118 = "Angle 113.5-118.5",
pred_123_128 = "Angle 123.5-128.5",
pred_128_133 = "Angle 128.5-133.5"))
