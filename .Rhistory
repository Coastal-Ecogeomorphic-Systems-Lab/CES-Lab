df <- read_excel("irish_adoption_gis.xlsx", sheet = "GIS_Data")
names(df) <- tolower(names(df))
df <- df %>%
mutate(
latitude = as.numeric(latitude),
longitude = as.numeric(longitude),
article_count = as.numeric(article_count)
) %>%
filter(!is.na(latitude), !is.na(longitude), !is.na(city))
# ---------------------------------------------------------
# Separate Pittsburg
# ---------------------------------------------------------
df_pitt <- df %>%
filter(city == "Pittsburg")
df_other <- df %>%
filter(city != "Pittsburg")
pts_all <- st_as_sf(df, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
pts_other <- st_as_sf(df_other, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
pts_pitt <- st_as_sf(df_pitt, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
# ---------------------------------------------------------
# Get U.S. state boundaries
# ---------------------------------------------------------
states_sf <- states(cb = TRUE, year = 2023) %>%
st_transform(4326)
states_conus <- states_sf %>%
filter(!STUSPS %in% c("AK", "HI", "PR"))
# ---------------------------------------------------------
# Build study-area extent from all points
# ---------------------------------------------------------
bbox <- st_bbox(pts_all)
xmin <- as.numeric(bbox["xmin"]) - 1.5
xmax <- as.numeric(bbox["xmax"]) + 1.5
ymin <- as.numeric(bbox["ymin"]) - 1.0
ymax <- as.numeric(bbox["ymax"]) + 1.0
study_area_box <- st_as_sfc(
st_bbox(
c(xmin = xmin, ymin = ymin, xmax = xmax, ymax = ymax),
crs = st_crs(pts_all)
)
)
states_crop <- st_crop(
states_conus,
xmin = xmin, xmax = xmax,
ymin = ymin, ymax = ymax
)
# ---------------------------------------------------------
# Main map
# ---------------------------------------------------------
main_map <- ggplot() +
geom_sf(
data = states_crop,
fill = "white",
color = "gray50",
linewidth = 0.4
) +
geom_sf(
data = pts_other,
shape = 21,
fill = "gray70",
size = 3.25
) +
geom_sf(
data = pts_pitt,
shape = 21,
fill = "black",
size = 3.25
) +
geom_text(
data = df_other,
aes(
x = longitude,
y = latitude,
label = city),
size = 3.5,
nudge_y = 0.125,
) +
geom_text(
data = df_pitt,
aes(
x = longitude,
y = latitude,
label = city
),
size = 4,
nudge_y = 0.125,
fontface = "bold"
) +
coord_sf(
xlim = c(xmin, xmax),
ylim = c(ymin, ymax),
expand = FALSE
) +
labs(
title = "Irish Adoption Articles by City",
x = NULL,
y = NULL
) +
theme_bw(base_size = 12) +
theme(
panel.grid.major = element_line(color = "gray88", linewidth = 0.3),
panel.grid.minor = element_blank(),
panel.border = element_rect(color = "black", linewidth = 0.8),
axis.text = element_text(size = 9, color = "black"),
axis.title = element_blank(),
plot.title = element_text(face = "bold", size = 15),
)
# ---------------------------------------------------------
# 7. U.S. inset map
# ---------------------------------------------------------
inset_map <- ggplot() +
geom_sf(
data = states_conus,
fill = "white",
color = "gray60",
linewidth = 0.25
) +
geom_sf(
data = study_area_box,
fill = NA,
color = "black",
linewidth = 0.8
) +
coord_sf(
xlim = c(-125, -66),
ylim = c(24, 50),
expand = FALSE
) +
theme_bw() +
theme(
axis.text = element_blank(),
axis.title = element_blank(),
axis.ticks = element_blank(),
panel.grid = element_blank(),
panel.border = element_rect(color = "black", linewidth = 0.6)
)
# ---------------------------------------------------------
# 8. Combine main map and inset
# ---------------------------------------------------------
final_map <- ggdraw() +
draw_plot(main_map) +
draw_plot(inset_map, x = 0.77, y = 0.1, width = 0.2, height = 0.2)
print(final_map)
# ---------------------------------------------------------
# 9. Save outputs
# ---------------------------------------------------------
ggsave(
filename = "irish_adoption_article_map_greyscale_no-counts.png",
plot = final_map,
width = 11,
height = 8,
dpi = 300
)
ggsave(
filename = "irish_adoption_article_map_greyscale_no-counts.pdf",
plot = final_map,
width = 11,
height = 8
)
# =========================================================
# Irish Adoption Articles by City
# Grayscale graduated symbology + theme_bw
# Pittsburg shown separately as black dot with bold label
# Variable label offsets for other cities based on article class
# Includes U.S. locator inset
# =========================================================
# Install if needed:
# install.packages(c("readxl", "sf", "ggplot2", "dplyr", "tigris", "cowplot"))
library(readxl)
library(sf)
library(ggplot2)
library(dplyr)
library(tigris)
library(cowplot)
options(tigris_use_cache = TRUE)
# ---------------------------------------------------------
# Read Excel file
# ---------------------------------------------------------
df <- read_excel("irish_adoption_gis.xlsx", sheet = "GIS_Data")
names(df) <- tolower(names(df))
df <- df %>%
mutate(
latitude = as.numeric(latitude),
longitude = as.numeric(longitude),
article_count = as.numeric(article_count)
) %>%
filter(!is.na(latitude), !is.na(longitude), !is.na(city))
# ---------------------------------------------------------
# Separate Pittsburg
# ---------------------------------------------------------
df_pitt <- df %>%
filter(city == "Pittsburg")
df_other <- df %>%
filter(city != "Pittsburg")
pts_all <- st_as_sf(df, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
pts_other <- st_as_sf(df_other, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
pts_pitt <- st_as_sf(df_pitt, coords = c("longitude", "latitude"), crs = 4326, remove = FALSE)
# ---------------------------------------------------------
# Get U.S. state boundaries
# ---------------------------------------------------------
states_sf <- states(cb = TRUE, year = 2023) %>%
st_transform(4326)
states_conus <- states_sf %>%
filter(!STUSPS %in% c("AK", "HI", "PR"))
# ---------------------------------------------------------
# Build study-area extent from all points
# ---------------------------------------------------------
bbox <- st_bbox(pts_all)
xmin <- as.numeric(bbox["xmin"]) - 1.5
xmax <- as.numeric(bbox["xmax"]) + 1.5
ymin <- as.numeric(bbox["ymin"]) - 1.0
ymax <- as.numeric(bbox["ymax"]) + 1.0
study_area_box <- st_as_sfc(
st_bbox(
c(xmin = xmin, ymin = ymin, xmax = xmax, ymax = ymax),
crs = st_crs(pts_all)
)
)
states_crop <- st_crop(
states_conus,
xmin = xmin, xmax = xmax,
ymin = ymin, ymax = ymax
)
# ---------------------------------------------------------
# Main map
# ---------------------------------------------------------
main_map <- ggplot() +
geom_sf(
data = states_crop,
fill = "white",
color = "gray50",
linewidth = 0.4
) +
geom_sf(
data = pts_other,
shape = 21,
fill = "gray70",
size = 3.25
) +
geom_sf(
data = pts_pitt,
shape = 21,
fill = "black",
size = 3.25
) +
geom_text(
data = df_other,
aes(
x = longitude,
y = latitude,
label = city),
size = 3.5,
nudge_y = 0.1,
) +
geom_text(
data = df_pitt,
aes(
x = longitude,
y = latitude,
label = city
),
size = 4,
nudge_y = 0.1,
fontface = "bold"
) +
coord_sf(
xlim = c(xmin, xmax),
ylim = c(ymin, ymax),
expand = FALSE
) +
labs(
title = "Irish Adoption Articles by City",
x = NULL,
y = NULL
) +
theme_bw(base_size = 12) +
theme(
panel.grid.major = element_line(color = "gray88", linewidth = 0.3),
panel.grid.minor = element_blank(),
panel.border = element_rect(color = "black", linewidth = 0.8),
axis.text = element_text(size = 9, color = "black"),
axis.title = element_blank(),
plot.title = element_text(face = "bold", size = 15),
)
# ---------------------------------------------------------
# 7. U.S. inset map
# ---------------------------------------------------------
inset_map <- ggplot() +
geom_sf(
data = states_conus,
fill = "white",
color = "gray60",
linewidth = 0.25
) +
geom_sf(
data = study_area_box,
fill = NA,
color = "black",
linewidth = 0.8
) +
coord_sf(
xlim = c(-125, -66),
ylim = c(24, 50),
expand = FALSE
) +
theme_bw() +
theme(
axis.text = element_blank(),
axis.title = element_blank(),
axis.ticks = element_blank(),
panel.grid = element_blank(),
panel.border = element_rect(color = "black", linewidth = 0.6)
)
# ---------------------------------------------------------
# 8. Combine main map and inset
# ---------------------------------------------------------
final_map <- ggdraw() +
draw_plot(main_map) +
draw_plot(inset_map, x = 0.77, y = 0.1, width = 0.2, height = 0.2)
print(final_map)
# ---------------------------------------------------------
# 9. Save outputs
# ---------------------------------------------------------
ggsave(
filename = "irish_adoption_article_map_greyscale_no-counts.png",
plot = final_map,
width = 11,
height = 8,
